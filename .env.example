# ============================================
#   🎵 DISCORD MUSIC BOT — CONFIGURACIÓN
# ============================================

# Token de tu bot de Discord
# Obtén uno en: https://discord.com/developers/applications
DISCORD_TOKEN=TU_TOKEN_AQUI

# ID de tu aplicación de Discord
CLIENT_ID=TU_CLIENT_ID_AQUI

# Spotify API (opcional pero recomendado para mejor soporte)
# Crea una app en: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=TU_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=TU_SPOTIFY_CLIENT_SECRET

# ============================================
# NOTAS:
# - Renombra este archivo a .env
# - NUNCA subas tu .env a GitHub
# - Asegúrate de tener yt-dlp instalado:
#   pip install yt-dlp  o  winget install yt-dlp
# ============================================
